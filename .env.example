# =============================================================================
# FHIR Query Validator Factory - Environment Configuration Example
# =============================================================================
# Copy this file to .env.local and update the values as needed.
# Never commit real credentials to version control.

# -----------------------------------------------------------------------------
# Default Server Configuration
# -----------------------------------------------------------------------------
# Logical key for the default server to use
FHIR_DEFAULT_SERVER_KEY=hapi

# Base URL of the FHIR server (used when server_key is not provided)
FHIR_SERVER_BASE=https://hapi.fhir.org/baseR4

# URL to fetch CapabilityStatement (optional, usually auto-derived)
# FHIR_METADATA_URL=https://hapi.fhir.org/baseR4/metadata

# -----------------------------------------------------------------------------
# Authentication Settings
# -----------------------------------------------------------------------------
# Set to true if connecting to a protected/authenticated server
FHIR_USE_AUTH=false

# Authentication type: "bearer" (static token) or "oauth2" (client credentials)
# FHIR_AUTH_TYPE=bearer

# Static Bearer token (used when FHIR_AUTH_TYPE=bearer)
# FHIR_AUTH_TOKEN=your-bearer-token-here

# -----------------------------------------------------------------------------
# OAuth2 Client Credentials (used when FHIR_AUTH_TYPE=oauth2)
# -----------------------------------------------------------------------------
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_TOKEN_URL=https://your-auth-server.com/oauth2/token
# OAUTH_SCOPE=fhir.read

# -----------------------------------------------------------------------------
# Optional: Additional Server Configurations
# -----------------------------------------------------------------------------
# You can define multiple servers and switch using server_key at runtime.
# Example for a protected server:
#
# FHIR_PROTECTED_SERVER_BASE=https://fhir.example.com/R4
# FHIR_PROTECTED_USE_AUTH=true
# FHIR_PROTECTED_AUTH_TYPE=oauth2
# OAUTH_CLIENT_ID_PROTECTED=...
# OAUTH_CLIENT_SECRET_PROTECTED=...
